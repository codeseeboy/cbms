# Backend API URL (REQUIRED for production frontend builds)
# - Local dev: http://localhost:4002
# - Vercel / Netlify / etc.: https://your-api.onrender.com (your Express backend URL)
# The Next.js app embeds NEXT_PUBLIC_* at BUILD time — set this in the hosting dashboard
# and trigger a new deploy after changing it.
NEXT_PUBLIC_API_URL=http://localhost:4002

# Optional: same URL for server-only code (Server Actions). If unset, NEXT_PUBLIC_API_URL is used.
# API_URL=https://your-api.onrender.com

# MongoDB Atlas connection
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.txju3tm.mongodb.net/?appName=Cluster0
MONGODB_DB=careerbuilder
